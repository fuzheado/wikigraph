# wikigraph — Configuration
# Copy to .env and customize. Reload Python to apply changes.

# User-Agent sent to the MediaWiki API. Must include a contact method
# (email or URL) to comply with Wikimedia policy.
WIKI_USER_AGENT=wikigraph/0.1.0 (https://github.com/fuzheado/wikigraph; your-email@example.com)

# MediaWiki API endpoint (default: en.wikipedia.org)
# WIKI_MW_API=https://en.wikipedia.org/w/api.php
# For Wikimedia Commons instead:
# WIKI_MW_API=https://commons.wikimedia.org/w/api.php

# Hatnote top-100 API endpoint template
# WIKI_HATNOTE_URL=https://top.hatnote.com/en/wikipedia/{year}/{month}/{day}.json

# Concurrent async HTTP requests (lower = gentler on API, higher = faster)
# WIKI_MAX_CONCURRENT=3

# Cache directory (relative to project root, or absolute path)
# WIKI_CACHE_DIR=.cache

# Hatnote cache TTL in seconds (default: 86400 = 24h)
# WIKI_HATNOTE_CACHE_TTL=86400

# MediaWiki cache TTL in seconds (default: 604800 = 7d)
# WIKI_MW_CACHE_TTL=604800
